RATE_LIMIT_ADMIN_UPLOAD_ABORT_PER_MIN=120
RATE_LIMIT_ADMIN_UPLOAD_ROUTE_PER_MIN=60
RATE_LIMIT_ALIAS_IP_PER_MIN=20
RATE_LIMIT_ALIAS_PW_PER_MIN=5
RATE_LIMIT_ALIAS_PW_PER_10MIN=20
RATE_LIMIT_PW_PER_MIN=5
RATE_LIMIT_PW_PER_10MIN=25
