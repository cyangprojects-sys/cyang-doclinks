ROUTE_TIMEOUT_API_V1_ALIASES_MS=15000
ROUTE_TIMEOUT_API_V1_SHARES_MS=20000
ROUTE_TIMEOUT_API_V1_TAKEDOWN_MS=20000
API_V1_DOCS_TIMEOUT_MS=15000

# --- Route timeout guardrails: admin / billing / security ---
ROUTE_TIMEOUT_ADMIN_DB_INDEX_AUDIT_MS=15000
ROUTE_TIMEOUT_ADMIN_AUDIT_EXPORT_MS=30000
ROUTE_TIMEOUT_ADMIN_ABUSE_MS=20000
ROUTE_TIMEOUT_ADMIN_DMCA_MS=20000
ROUTE_TIMEOUT_ADMIN_SECURITY_ROLLBACK_MS=20000
ROUTE_TIMEOUT_ADMIN_SECURITY_ORG_ACCESS_MS=15000
ROUTE_TIMEOUT_ADMIN_SECURITY_REQUEUE_SCANS_MS=20000
ROUTE_TIMEOUT_ADMIN_SECURITY_TENANT_FREEZE_MS=20000
ROUTE_TIMEOUT_ADMIN_SECURITY_TABLE_SIGNATURES_MS=12000
ROUTE_TIMEOUT_UPLOAD_PRESIGN_MS=20000
ROUTE_TIMEOUT_UPLOAD_ABORT_MS=15000
ROUTE_TIMEOUT_UPLOAD_COMPLETE_MS=45000
ROUTE_TIMEOUT_BILLING_CHECKOUT_MS=15000
ROUTE_TIMEOUT_BILLING_INVOICES_MS=15000
ROUTE_TIMEOUT_BILLING_PORTAL_MS=15000
