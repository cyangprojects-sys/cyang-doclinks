ROUTE_TIMEOUT_BILLING_SYNC_MS=30000
ROUTE_TIMEOUT_STRIPE_WEBHOOK_MS=15000

# --- Route timeout guardrails: delivery / scan / preview ---
ROUTE_TIMEOUT_CRON_SCAN_MS=120000
VIEWER_OFFICE_FETCH_TIMEOUT_MS=15000
ROUTE_TIMEOUT_SERVE_MS=25000
ROUTE_TIMEOUT_TICKET_SERVE_MS=30000
ROUTE_TIMEOUT_ALIAS_RAW_MS=25000
ROUTE_TIMEOUT_SHARE_RAW_MS=25000

# --- Optional/advanced toggles observed in runtime code ---
# [OPTIONAL] Booleans: use 1/0 for explicit behavior changes
ENABLE_STRICT_ENV_VALIDATION=1
TRUST_PROXY_HEADERS=0
CRON_HIDE_UNAUTHORIZED=1
DEV_ALLOW_INSECURE_FALLBACK=0
DISABLE_SECURITY_TELEMETRY_DB=0
SECURITY_TELEMETRY_DB_ENABLED=0
IMMUTABLE_AUDIT_STRICT=0
FORCE_R2_SSE=1
TRUST_PLATFORM_PROXY_HEADERS=0
SECURITY_GLOBAL_SERVE_DISABLE=0
SECURITY_SHARE_SERVE_DISABLE=0
SECURITY_ALIAS_SERVE_DISABLE=0
SECURITY_TICKET_SERVE_DISABLE=0
SECURITY_TEST_NO_DB=0

# Deprecated / alias config kept for compatibility only:
# Leave these blank in new deployments. Set them only during migration windows and keep them aligned with the
# preferred names above so operators do not end up debugging two sources of truth.
# - Prefer R2_BUCKET over R2_BUCKET_NAME
# - Prefer SUPPORT_EMAIL over CONTACT_EMAIL
# - Prefer SECURITY_EMAIL over RESPONSIBLE_DISCLOSURE_EMAIL
# - Prefer DMCA_EMAIL over DMCA_CONTACT_EMAIL
# - Prefer EMAIL_FROM over RESEND_FROM
R2_BUCKET_NAME=example-bucket
R2_PREFIX=docs/
SHARE_SALT=replace_with_random_hex_secret
DEVICE_TRUST_SALT=replace_with_random_hex_secret
CUSTOM_HASH_SALT=replace_with_random_hex_secret
OWNER_EMAILS=owner@example.com,second-owner@example.com
NEXT_PUBLIC_GOOGLE_ENABLED=1
NEXT_PUBLIC_ENTERPRISE_SSO_ENABLED=0
OIDC_ISSUER=https://idp.example.com
OIDC_CLIENT_ID=example-oidc-client-id
OIDC_CLIENT_SECRET=example-oidc-client-secret
CONTACT_EMAIL=
RESPONSIBLE_DISCLOSURE_EMAIL=
DMCA_EMAIL=dmca@cyang.io
DMCA_CONTACT_EMAIL=
RESEND_FROM="Example App <noreply@example.com>"
OBSERVABILITY_ERROR_WEBHOOK=https://hooks.example.com/errors

# --- In-process cache tuning ---
ADMIN_SHELL_CONTEXT_CACHE_MS=30000
BILLING_FLAGS_CACHE_MS=120000
DASHBOARD_SCHEMA_CACHE_MS=60000
DASHBOARD_OVERVIEW_CACHE_MS=30000
HEALTH_SUMMARY_CACHE_MS=30000
PLAN_CACHE_MS=10000
SECURITY_FREEZE_CACHE_MS=5000
STATUS_PUBLIC_HEALTH_CACHE_MS=120000

# --- Share/alias defaults ---
ALIAS_DEFAULT_TTL_DAYS=30
FREE_SHARE_TTL_DAYS=7
FREE_DEFAULT_SHARE_MAX_VIEWS=5
EXPIRED_SHARES_REVOKE_BATCH=500

# --- Access ticket replay controls ---
ACCESS_TICKET_REPLAY_ENABLED=0
ACCESS_TICKET_REPLAY_GRACE_SECONDS_PREVIEW=30
ACCESS_TICKET_REPLAY_GRACE_SECONDS_DOWNLOAD=30
ACCESS_TICKET_REPLAY_GRACE_SECONDS_WATERMARKED_DOWNLOAD=30
ACCESS_TICKET_REQUIRE_IP_MATCH=1
ACCESS_TICKET_REQUIRE_UA_MATCH=1

# --- Additional auth route limits ---
RATE_LIMIT_AUTH_EMAIL_START_IP_PER_MIN=10
RATE_LIMIT_AUTH_EMAIL_CONSUME_IP_PER_MIN=20
RATE_LIMIT_AUTH_GOOGLE_START_IP_PER_MIN=10
RATE_LIMIT_AUTH_GOOGLE_CALLBACK_IP_PER_MIN=20
RATE_LIMIT_ORG_AUTH_START_IP_PER_MIN=20
RATE_LIMIT_MANUAL_SIGNUP_IP_PER_MIN=10
RATE_LIMIT_SIGNUP_CONSENT_IP_PER_MIN=20
RATE_LIMIT_SHARE_DOWNLOAD_IP_PER_MIN=30
RATE_LIMIT_VIEWER_OFFICE_PREVIEW_IP_PER_MIN=30
RATE_LIMIT_UPLOAD_PRESIGN_FREE_IP_PER_MIN=12
RATE_LIMIT_UPLOAD_COMPLETE_FREE_IP_PER_MIN=12

# --- Stripe/webhook hardening ---
STRIPE_WEBHOOK_MAX_BODY_BYTES=262144
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_ALLOW_TRIALING_ENTITLEMENT=0
STRIPE_ALLOW_GRACE_ENTITLEMENT=0

# --- Billing/maintenance ---
BILLING_MAINTENANCE_MAX_USERS=500
KEY_ROTATION_CRON_MAX_JOBS=1
AUTO_KEY_ROTATION_ENABLED=0
AUTO_KEY_ROTATE_FROM=
AUTO_KEY_ROTATE_BATCH=250
BACKUP_AUTOMATION_ENABLED=1
BACKUP_WEBHOOK_URL=https://backup-webhook.example.com/run
BACKUP_STATUS_WEBHOOK_TOKEN=replace_with_long_random_token
BACKUP_MAX_AGE_HOURS=24
RECOVERY_DRILL_DAYS=30
WEBHOOK_DELIVERY_TIMEOUT_MS=10000
STATUS_DAILY_SEND_HOUR=6
STATUS_DAILY_SEND_TIMEZONE=UTC
STATUS_DAILY_SEND_MAX_RECIPIENTS=500
STATUS_DAILY_SEND_CONCURRENCY=8

# --- Scan pipeline tuning ---
SCAN_CRON_BATCH=25
SCAN_MAX_ATTEMPTS=5
SCAN_RETRY_BASE_MINUTES=5
SCAN_RETRY_MAX_MINUTES=60
SCAN_RUNNING_TIMEOUT_MINUTES=20
MALWARE_SCANNER_REQUIRE_ARCHIVE_DEEP_SCAN=false

# --- Orphan sweep ---
ORPHAN_SWEEP_DELETE=false
ORPHAN_SWEEP_MAX_OBJECTS=1000
ORPHAN_SWEEP_WEEKDAY_UTC=0

# --- Security anomaly thresholds ---
ABUSE_REPORT_SPIKE_THRESHOLD=20
ABUSE_REPORT_SPIKE_WINDOW_MINUTES=10
PRESIGN_FAILURE_SPIKE_THRESHOLD=15
PRESIGN_FAILURE_SPIKE_WINDOW_MINUTES=10
SCAN_FAILURE_SPIKE_THRESHOLD=10
SCAN_FAILURE_SPIKE_WINDOW_MINUTES=10
UPLOAD_SPIKE_THRESHOLD=120
UPLOAD_SPIKE_WINDOW_MINUTES=10
VIEW_SPIKE_THRESHOLD=500
VIEW_SPIKE_WINDOW_MINUTES=10
DB_ERROR_SPIKE_THRESHOLD=20
DB_ERROR_SPIKE_WINDOW_MINUTES=10
ALIAS_DENIED_SPIKE_THRESHOLD=60
ALIAS_DENIED_SPIKE_WINDOW_MINUTES=10
TOKEN_DENIED_SPIKE_THRESHOLD=80
TOKEN_DENIED_SPIKE_WINDOW_MINUTES=10
STORAGE_SPIKE_SINGLE_BYTES=104857600
STORAGE_SPIKE_BURST_BYTES=262144000

# --- Sentry build-time values (optional) ---
SENTRY_ORG=example-org
SENTRY_PROJECT=example-project
SENTRY_AUTH_TOKEN=example-sentry-token
