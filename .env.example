# Core database
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=your-account-id
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=doclinks

# Encryption / auth / ops secrets
DOC_MASTER_KEYS=v1:base64-32-byte-key
VIEW_SALT=replace-with-random-secret
NEXTAUTH_SECRET=replace-with-random-secret
CRON_SECRET=replace-with-random-secret

# Stripe billing
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_IDS=price_xxx
STRIPE_ENFORCE_ENTITLEMENT=true

# Upload / serve safety
UPLOAD_ABSOLUTE_MAX_BYTES=26214400
ALLOW_UNENCRYPTED_SERVE=false
