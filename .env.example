# Example environment file for local development, CI proof runs, and deployment setup.
# Use fake/sample values here only. Do NOT commit real secrets.
# This file is intentionally safe to copy into `.env.local` for a clean build-proof run.
# Production deployments must replace the placeholder values with real secrets and live service config.
# See `docs/environment-ownership.md` for proof/local/deploy ownership and the intentional-extra env manifest.
# Annotation format:
# - [REQUIRED] must be set for production
# - [OPTIONAL] safe default exists, but set explicitly when behavior matters

# --- Environment Mode ---
# [REQUIRED] Kept explicit for env-audit completeness. Playwright proof runs restore the process-managed NODE_ENV so this line
# does not change helper-test semantics in a clean checkout.
NODE_ENV=production
# [OPTIONAL] Platform environment labels
VERCEL=0
VERCEL_ENV=production
VERCEL_URL=
CF_PAGES=0
CF_WORKER=0
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_BUILD_SHA=dev-local

# --- Core app/auth [REQUIRED unless noted] ---
# [REQUIRED]
APP_URL=https://example.com
NEXT_PUBLIC_APP_URL=https://example.com
NEXTAUTH_URL=https://example.com
# [OPTIONAL]
BRAND_NAME="Example Brand"
BRAND_PRIMARY_COLOR="#0B2A4A"
OWNER_EMAIL=owner@example.com
OIDC_REQUIRE_EMAIL_VERIFIED=true
MFA_ENFORCE_ADMIN=0
SIGNUP_ENABLED=1

# --- Public runtime config (preferred public-shell inputs) ---
# These are the values public marketing/trust pages should rely on instead of DB-backed runtime flags.
PRICING_UI_ENABLED=0
NEXT_PUBLIC_SIGNUP_ENABLED=true
SUPPORT_EMAIL=support@cyang.io
PRIVACY_EMAIL=privacy@cyang.io
SECURITY_EMAIL=security@cyang.io
LEGAL_EMAIL=legal@cyang.io

# --- Secrets (replace in real env) ---
# [REQUIRED]
# Preferred secret names are APP_SECRET / AUTH_SECRET / NEXTAUTH_SECRET.
# Keep all three aligned until legacy aliases can be fully retired from all environments.
APP_SECRET=replace_with_32_byte_base64_secret
AUTH_SECRET=replace_with_random_hex_secret
NEXTAUTH_SECRET=replace_with_random_hex_secret
VIEW_SALT=replace_with_random_hex_secret
API_KEY_SALT=replace_with_random_hex_secret
SECURITY_TELEMETRY_HASH_KEY=replace_with_random_hex_secret
# [REQUIRED][CRITICAL] Used by all cron/admin maintenance routes
CRON_SECRET=replace_with_random_hex_secret
SHARE_COOKIE_SECRET=replace_with_random_hex_secret
ADMIN_COOKIE_SECRET=replace_with_random_hex_secret
ADMIN_PASSWORD=replace_with_strong_password
OIDC_SECRETS_KEY=replace_with_32_byte_base64_secret

# --- Database ---
# [REQUIRED]
DATABASE_URL=

# --- Storage (Cloudflare R2) ---
# [REQUIRED]
R2_ACCOUNT_ID=example-account-id
R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=example-r2-access-key-id
R2_SECRET_ACCESS_KEY=example-r2-secret-access-key
R2_BUCKET=example-bucket
# [OPTIONAL] Explicit region/bucket validation guardrails
R2_ALLOWED_BUCKETS=example-bucket,example-backup-bucket
# [OPTIONAL] Force SSE on uploaded objects

# --- Encryption keys ---
# JSON array of key objects: id, key_b64 (32-byte key), active
DOC_MASTER_KEYS=[{"id":"k1","key_b64":"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=","active":true}]

# --- Google OAuth ---
GOOGLE_CLIENT_ID=example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=example-google-client-secret

# --- Email / resend ---
# Preferred sender key: EMAIL_FROM
EMAIL_FROM="Example App <noreply@example.com>"
RESEND_API_KEY=re_example_key

# --- Stripe ---
# [REQUIRED]
STRIPE_SECRET_KEY=sk_test_example
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_example
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_IDS=price_example_monthly,price_example_yearly
# [OPTIONAL]
STRIPE_GRACE_DAYS=7
STRIPE_ENFORCE_ENTITLEMENT=1

# --- Pricing/plan toggles ---
ENFORCE_PLAN_LIMITS=1
PRO_PLAN_ENABLED=0
PRO_SOFT_MAX_ACTIVE_SHARES=1000
PRO_SOFT_MAX_VIEWS_PER_MONTH=50000
PRO_SOFT_MAX_EGRESS_BYTES=32212254720
PRO_SHARE_CREATE_PER_MIN=90
PRO_SHARE_CREATE_BURST_LIMIT=300
PRO_SHARE_CREATE_BURST_WINDOW_SECONDS=300
PRO_VIEW_OVERAGE_PER_MIN=120

# --- Access ticket ---
ACCESS_TICKET_TTL_SECONDS=30
ACCESS_TICKET_SIGNED_URL_TTL_SECONDS=30

# --- Upload/scan limits ---
UPLOAD_ABSOLUTE_MAX_BYTES=104857600
SCAN_ABS_MAX_BYTES=104857600
PDF_MAX_PAGES=500

# --- Malware scanning ---
MALWARE_SCANNER_URL=https://scanner.example.com/scan
MALWARE_SCANNER_AUTH_TOKEN=example-scanner-token
MALWARE_SCANNER_TIMEOUT_MS=20000
MALWARE_SCANNER_STRICT=true

# --- CSP ---
# [OPTIONAL] Extra connect-src targets (comma or space delimited). 'self' is always included automatically.
CSP_CONNECT_SRC=https://api.stripe.com,https://js.stripe.com,https://checkout.stripe.com,https://*.sentry.io

# --- Analytics ---
ANALYTICS_AGGREGATE_DAYS_BACK=120
PERF_TELEMETRY_ENABLED=1

# --- Audit / Lighthouse tooling ---
# Dedicated port for local Lighthouse runs so they do not collide with app/test ports.
LIGHTHOUSE_PORT=3300
# Auto-build before bundle budget checks when manifests are missing.
BUNDLE_BUDGETS_AUTO_BUILD=1

# --- Watermark defaults ---
WATERMARK_DEFAULT_ENABLED=true
WATERMARK_DEFAULT_TEXT="EXAMPLE - Confidential"

# --- Retention ---
RETENTION_ENABLED=true
RETENTION_DAYS=90
RETENTION_DAYS_DAILY=365
RETENTION_SHARE_GRACE_DAYS=0
RETENTION_AUDIT_R2_ORPHANS=true
RETENTION_DELETE_R2_ORPHANS=true
RETENTION_DELETE_EXPIRED_SHARES=true
RETENTION_R2_AUDIT_MAX_OBJECTS=1000

# --- Scan queue alerting ---
SCAN_QUEUE_STALE_ALERT_MINUTES=5
SCAN_QUEUE_STALE_ALERT_COUNT=1
# Pending scan delay threshold (minutes) used in dashboard scan-delay signals.
SCAN_PENDING_DELAY_THRESHOLD=25

# --- Abuse block thresholds ---
ABUSE_BLOCK_TTL_SECONDS=1800
ABUSE_BLOCK_SERVE_THRESHOLD=40
ABUSE_BLOCK_SERVE_WINDOW_SECONDS=60
ABUSE_BLOCK_TOKEN_THRESHOLD=10
ABUSE_BLOCK_TOKEN_WINDOW_SECONDS=60
ABUSE_BLOCK_PRESIGN_THRESHOLD=15
ABUSE_BLOCK_PRESIGN_WINDOW_SECONDS=60
ABUSE_BLOCK_STRIPE_SIG_THRESHOLD=10
ABUSE_BLOCK_STRIPE_SIG_WINDOW_SECONDS=60

# --- Rate limits: shared public/auth baselines ---
RATE_LIMIT_API_IP_PER_MIN=120
RATE_LIMIT_UPLOAD_PRESIGN_IP_PER_MIN=10
RATE_LIMIT_UPLOAD_COMPLETE_IP_PER_MIN=10
RATE_LIMIT_ABUSE_REPORT_IP_PER_MIN=10
RATE_LIMIT_STATUS_SUBSCRIBE_IP_PER_MIN=12
RATE_LIMIT_PUBLIC_FUNNEL_PER_MIN=120
RATE_LIMIT_BILLING_CHECKOUT_PER_MIN=60
RATE_LIMIT_BACKUP_STATUS_IP_PER_MIN=30
RATE_LIMIT_HEALTH_IP_PER_MIN=300
RATE_LIMIT_MANUAL_PASSWORD_RESET_REQUEST_IP_PER_MIN=8
RATE_LIMIT_MANUAL_PASSWORD_RESET_COMPLETE_IP_PER_MIN=8

# --- Rate limits: admin / owner / billing ---
RATE_LIMIT_ADMIN_ABUSE_PER_MIN=30
RATE_LIMIT_ADMIN_BILLING_CHECKOUT_PER_MIN=60
RATE_LIMIT_ADMIN_BILLING_OVERRIDE_PER_MIN=60
RATE_LIMIT_ADMIN_BILLING_PORTAL_PER_MIN=60
RATE_LIMIT_ADMIN_BILLING_SETTINGS_PER_MIN=60
RATE_LIMIT_ADMIN_BILLING_SYNC_PER_MIN=30
RATE_LIMIT_ADMIN_BILLING_INVOICES_PER_MIN=60
RATE_LIMIT_ADMIN_BILLING_STATUS_PER_MIN=60
RATE_LIMIT_ADMIN_ANALYTICS_AGGREGATE_PER_MIN=30
RATE_LIMIT_ADMIN_AUDIT_EXPORT_PER_MIN=30
RATE_LIMIT_ADMIN_DB_INDEX_AUDIT_PER_MIN=20
RATE_LIMIT_ADMIN_RETENTION_RUN_PER_MIN=10
RATE_LIMIT_ADMIN_SECURITY_FREEZE_PER_MIN=60
RATE_LIMIT_ADMIN_SECURITY_KEY_OPS_PER_MIN=120
RATE_LIMIT_ADMIN_SECURITY_KEYS_PER_MIN=60
RATE_LIMIT_ADMIN_SECURITY_ORG_ACCESS_PER_MIN=60
RATE_LIMIT_ADMIN_SECURITY_RBAC_PER_MIN=60
RATE_LIMIT_ADMIN_SECURITY_REQUEUE_PER_MIN=30
RATE_LIMIT_ADMIN_SECURITY_TABLE_SIGNATURES_PER_MIN=120
RATE_LIMIT_ADMIN_SECURITY_TENANT_FREEZE_PER_MIN=60
RATE_LIMIT_ADMIN_UPLOAD_ABORT_PER_MIN=120
RATE_LIMIT_ADMIN_UPLOAD_ROUTE_PER_MIN=60
RATE_LIMIT_VIEWER_DOCS_STATUS_PER_MIN=90

# --- Rate limits: share / alias / document delivery ---
RATE_LIMIT_ALIAS_IP_PER_MIN=20
RATE_LIMIT_ALIAS_PW_PER_MIN=5
RATE_LIMIT_ALIAS_PW_PER_10MIN=20
RATE_LIMIT_PW_PER_MIN=5
RATE_LIMIT_PW_PER_10MIN=25
RATE_LIMIT_SHARE_IP_PER_MIN=30
RATE_LIMIT_SHARE_TOKEN_PER_MIN=15
RATE_LIMIT_SERVE_IP_PER_MIN=60
RATE_LIMIT_SERVE_TOKEN_PER_MIN=30
RATE_LIMIT_TICKET_IP_PER_MIN=15
RATE_LIMIT_STRIPE_WEBHOOK_IP_PER_MIN=60

# --- Rate limits: cron / background automation ---
RATE_LIMIT_CRON_AGGREGATE_PER_MIN=30
RATE_LIMIT_CRON_BILLING_SYNC_PER_MIN=30
RATE_LIMIT_CRON_KEY_ROTATION_PER_MIN=30
RATE_LIMIT_CRON_NIGHTLY_PER_MIN=10
RATE_LIMIT_CRON_ORPHAN_SWEEP_PER_MIN=20
RATE_LIMIT_CRON_RETENTION_PER_MIN=20
RATE_LIMIT_CRON_SCAN_PER_MIN=30
RATE_LIMIT_CRON_WEBHOOKS_PER_MIN=30

# --- Route timeout guardrails: health / public / diagnostics ---
ROUTE_TIMEOUT_HEALTH_MS=3000
ROUTE_TIMEOUT_BACKUP_STATUS_MS=10000
ROUTE_TIMEOUT_PUBLIC_FUNNEL_MS=7500
ROUTE_TIMEOUT_STATUS_SUBSCRIBE_MS=10000
ROUTE_TIMEOUT_MANUAL_PASSWORD_RESET_REQUEST_MS=10000
ROUTE_TIMEOUT_MANUAL_PASSWORD_RESET_COMPLETE_MS=10000
