{
  "name": "cyang-doclinks",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.16.0 <25",
    "npm": ">=10.9.2 <12"
  },
  "volta": {
    "node": "22.16.0",
    "npm": "10.9.2"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:playwright": "playwright test",
    "test": "node scripts/run-test-suite.mjs",
    "lint": "eslint",
    "typecheck": "node scripts/typecheck.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "db:migrations:verify": "node scripts/migrate.mjs verify",
    "audit:admin-routes": "node scripts/audit-admin-route-guards.mjs",
    "audit:admin-polling": "node scripts/audit-admin-polling-targets.mjs",
    "audit:public-rendering": "node scripts/audit-public-rendering.mjs",
    "audit:route-handlers": "node scripts/audit-route-handler-rendering.mjs",
    "audit:polling": "node scripts/audit-polling-discipline.mjs",
    "audit:bundle-budgets": "node scripts/audit-bundle-budgets.mjs",
    "audit:env-example": "node scripts/check-env-example.mjs",
    "release:gate": "node scripts/release-gate.mjs",
    "production-readiness": "node scripts/production-readiness.mjs",
    "restore:verify": "node scripts/restore-verify.mjs",
    "fire-drill:staging": "node scripts/fire-drill-staging.mjs",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:a11y:ci": "start-server-and-test \"npm run start\" http://127.0.0.1:3000 \"npm run test:a11y\"",
    "test:attack": "playwright test tests/attack-sim.spec.ts",
    "test:attack:ci": "start-server-and-test \"npm run start\" http://127.0.0.1:3000 \"npm run test:attack\"",
    "test:billing:webhook": "playwright test tests/billing-webhook.spec.ts",
    "test:billing:webhook:ci": "start-server-and-test \"npm run start\" http://127.0.0.1:3000 \"npm run test:billing:webhook\"",
    "test:security:state": "playwright test tests/security-state.spec.ts",
    "test:security:state:ci": "start-server-and-test \"npm run start\" http://127.0.0.1:3000 \"npm run test:security:state\"",
    "test:security:freeze": "playwright test tests/security-freeze.spec.ts",
    "test:security:freeze:ci": "start-server-and-test \"npm run start\" http://127.0.0.1:3000 \"npm run test:security:freeze\"",
    "audit:lighthouse": "node scripts/run-lhci.mjs",
    "audit:browser": "npm run test:a11y:ci",
    "audit:browser:ci": "npm run test:a11y:ci && npm run audit:lighthouse",
    "prove:build": "node scripts/prove-build.mjs",
    "docker:build": "docker build -t cyang-doclinks-app .",
    "docker:test:image": "docker build -f Dockerfile.test -t cyang-doclinks-test .",
    "docker:proof:image": "docker build --no-cache -f Dockerfile.proof -t cyang-doclinks-proof ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1011.0",
    "@aws-sdk/s3-request-presigner": "^3.1011.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/nextjs": "^10.44.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "next": "^16.1.7",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "openid-client": "^6.8.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.4",
    "zod": "^4.3.6"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.8",
    "serialize-javascript": "^7.0.0",
    "flatted": "^3.4.1",
    "tmp": "^0.2.5",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.7",
    "lighthouse": "^12.6.1",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
